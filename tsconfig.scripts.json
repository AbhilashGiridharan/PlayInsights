{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist-scripts",
    "rootDir": ".",
    "skipLibCheck": true
  },
  "include": ["scripts/**/*.ts", "playwright.config.ts"]
}
