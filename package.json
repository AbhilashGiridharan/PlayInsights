{
  "name": "playwright-results-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright test results dashboard – GitHub Pages static site",
  "scripts": {
    "test": "playwright test",
    "summarize": "ts-node --project tsconfig.scripts.json scripts/summarize-results.ts",
    "update:index": "ts-node --project tsconfig.scripts.json scripts/update-index.ts",
    "posttest": "npm run summarize && npm run update:index"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.0",
    "@types/node": "^20.12.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
